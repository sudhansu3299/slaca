# ------------------------------------------------------------
# Core runtime
# ------------------------------------------------------------
OPENAI_API_KEY=
OPENCODE_API_KEY=
OPENCODE_BASE_URL=
OPENAI_BASE_URL=

# ------------------------------------------------------------
# Temporal / queues
# ------------------------------------------------------------
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TASK_QUEUE=collections-queue
TASK_QUEUE_LIVE=collections-queue-live

# ------------------------------------------------------------
# Data stores (Docker defaults)
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB=collections_ai
BORROWER_DB_URL=postgresql://collections:collections@collections-db:5432/collections_ai

# ------------------------------------------------------------
# Worker/server mode flags
# ------------------------------------------------------------
USE_LLM_MOCK=1
USE_REAL_CHAT=0
SKIP_LLM_JUDGE=1
EMBEDDED_WORKER=0

# ------------------------------------------------------------
# Voice + telephony
# ------------------------------------------------------------
VOICE_PROVIDER=mock
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
CALLER_NUMBER=

# IMPORTANT:
# Current Twilio/Vapi integration in this repo is wired for a single
# configured borrower phone flow. Set BORROWER_PHONE to the target number.
# Replace with your own number before live testing.
BORROWER_PHONE=+919999999999

# ------------------------------------------------------------
# Optional observability
# ------------------------------------------------------------
LOGFIRE_TOKEN=